generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================
// USUARIOS Y ROLES
// =============================================

model Usuario {
  id           String      @id @default(cuid())
  email        String      @unique
  password     String
  nombre       String
  rol          Rol
  creadoEn     DateTime    @default(now())
  estudianteId String?     @unique
  estudiante   Estudiante? @relation(fields: [estudianteId], references: [id])
}

enum Rol {
  ESTUDIANTE
  PSICOLOGO
  ORIENTADOR
  DIRECTOR
  ADMIN
}

// =============================================
// ESTUDIANTES
// =============================================

model Estudiante {
  id            String     @id @default(cuid())
  curp          String     @unique
  nombre        String
  edad          Int
  sexo          Sexo
  grado         String
  grupo         String
  escuela       String
  tokenEncuesta String     @unique @default(cuid())
  usuario       Usuario?
  tamizajes     Tamizaje[]
  citas         Cita[]
  respuestasRaw RespuestasCuestionario[]
  expediente    ExpedienteClinico?
  sesiones      Sesion[]
}

// =============================================
// RESPUESTAS CRUDAS DEL CUESTIONARIO
// =============================================

model RespuestasCuestionario {
  id           String     @id @default(cuid())
  fecha        DateTime   @default(now())
  estudianteId String
  respuestas   Json
  procesado    Boolean    @default(false)
  estudiante   Estudiante @relation(fields: [estudianteId], references: [id])
}

enum Sexo {
  MASCULINO
  FEMENINO
  OTRO
}

// =============================================
// TAMIZAJES (resultado del SENA + clasificacion ML)
// =============================================

model Tamizaje {
  id           String   @id @default(cuid())
  fecha        DateTime @default(now())
  estudianteId String

  // Escalas de control
  inc Float
  neg Float
  pos Float

  // Indices globales (puntuacion T)
  glo_t Int
  emo_t Int
  con_t Int
  eje_t Int
  ctx_t Int
  rec_t Int

  // Problemas interiorizados (T)
  dep_t Int
  ans_t Int
  asc_t Int
  som_t Int
  pst_t Int
  obs_t Int

  // Problemas exteriorizados (T)
  ate_t Int
  hip_t Int
  ira_t Int
  agr_t Int
  des_t Int
  ant_t Int

  // Otros problemas (T)
  sus_t Int
  esq_t Int
  ali_t Int

  // Problemas contextuales (T)
  fam_t Int
  esc_t Int
  com_t Int

  // Vulnerabilidades (T)
  reg_t Int
  bus_t Int

  // Recursos personales (T)
  aut_t Int
  soc_t Int
  cnc_t Int

  // Resultado del modelo ML
  tipoCaso      TipoCaso
  semaforo      Semaforo
  observaciones String?
  itemsCriticos Json

  estudiante Estudiante @relation(fields: [estudianteId], references: [id])
}

enum TipoCaso {
  INCONSISTENCIA
  SIN_RIESGO
  IMPRESION_POSITIVA
  IMPRESION_NEGATIVA
  CON_RIESGO
}

enum Semaforo {
  VERDE
  AMARILLO
  ROJO
  ROJO_URGENTE
}

// =============================================
// CITAS
// =============================================

model Cita {
  id           String     @id @default(cuid())
  fecha        DateTime
  estado       EstadoCita @default(PENDIENTE)
  notas        String?
  estudianteId String
  estudiante   Estudiante @relation(fields: [estudianteId], references: [id])
  sesion       Sesion?
}

enum EstadoCita {
  PENDIENTE
  CONFIRMADA
  COMPLETADA
  CANCELADA
}

// =============================================
// EXPEDIENTE CLÍNICO Y SESIONES
// =============================================

model ExpedienteClinico {
  id                    String           @id @default(cuid())
  estudianteId          String           @unique
  motivoConsulta        String?
  antecedentes          String?
  diagnosticoPreliminar String?
  planIntervencion      String?
  estado                EstadoExpediente @default(ACTIVO)
  abiertaEn             DateTime         @default(now())
  actualizadaEn         DateTime         @updatedAt
  estudiante            Estudiante       @relation(fields: [estudianteId], references: [id])
}

model Sesion {
  id              String     @id @default(cuid())
  fecha           DateTime   @default(now())
  tipo            TipoSesion @default(SEGUIMIENTO)
  motivo          String?
  notas           String
  acuerdos        String?
  planActualizado String?
  citaId          String?    @unique
  estudianteId    String
  estudiante      Estudiante @relation(fields: [estudianteId], references: [id])
  cita            Cita?      @relation(fields: [citaId], references: [id])
}

enum EstadoExpediente {
  ACTIVO
  CERRADO
  DERIVADO
  EN_ESPERA
}

enum TipoSesion {
  EVALUACION_INICIAL
  SEGUIMIENTO
  INTERVENCION
  CRISIS
  CIERRE
  DEVOLUCION
}

// =============================================
// HISTÓRICO SENA — corpus de entrenamiento ML
// =============================================

model HistoricoSENA {
  id         String   @id @default(cuid())
  origen     String   @default("importacion")
  fecha      DateTime
  edad       Int
  sexo       String
  baremo     String?
  respuestas String?  // cadena de 188 dígitos
  semaforo   Semaforo // derivado con calcularResultado()

  // Escalas de control (puntuación directa + T)
  pdInc Float @default(0)
  ptInc Int   @default(50)
  pdNeg Float @default(0)
  ptNeg Int   @default(50)
  pdPos Float @default(0)
  ptPos Int   @default(50)

  // Índices globales (puntuación T)
  gloT Int @default(50)
  emoT Int @default(50)
  conT Int @default(50)
  ejeT Int @default(50)
  ctxT Int @default(50)
  recT Int @default(50)

  // Problemas interiorizados (T)
  depT Int @default(50)
  ansT Int @default(50)
  ascT Int @default(50)
  somT Int @default(50)
  pstT Int @default(50)
  obsT Int @default(50)

  // Problemas exteriorizados (T)
  ateT Int @default(50)
  hipT Int @default(50)
  iraT Int @default(50)
  agrT Int @default(50)
  desT Int @default(50)
  antT Int @default(50)

  // Otros problemas (T)
  susT Int @default(50)
  esqT Int @default(50)
  aliT Int @default(50)

  // Problemas contextuales (T)
  famT Int @default(50)
  escT Int @default(50)
  comT Int @default(50)

  // Vulnerabilidades (T)
  regT Int @default(50)
  busT Int @default(50)

  // Recursos personales (T)
  autT Int @default(50)
  socT Int @default(50)
  cncT Int @default(50)

  creadoEn DateTime @default(now())
}

// =============================================
// HISTÓRICO DE ENTRENAMIENTOS ML
// =============================================

model EntrenamientoML {
  id          String   @id @default(cuid())
  fecha       DateTime @default(now())
  nRegistros  Int
  trainSize   Float
  accuracy    Float
  cvMean      Float
  cvStd       Float
  nEstimators Int
  report      Json     // classification_report por clase
  importance  Json     // [{ feature, importance }, ...]
}
