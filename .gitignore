# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma

# Claude Code (configuración local)
.claude/

# Modelos ML binarios (regenerar con entrenar_sena.py)
# modelo.pkl incluido intencionalmente para despliegue en Railway
ml-api/models/*.pkl
!ml-api/models/modelo.pkl

# Python cache
ml-api/**/__pycache__/
ml-api/**/*.pyc

.vercel
